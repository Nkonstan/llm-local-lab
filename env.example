# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and edit as needed.
# .env is gitignored — never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Model pulled automatically on first start.
# Any Ollama model tag works: https://ollama.com/library
# Examples:
#   qwen3:2b          ~1.5 GB  — fast, great reasoning
#   minicpm5:1b       ~0.6 GB  — best under 2B, edge-optimised
#   llama3.2:3b       ~2.0 GB  — solid general purpose
#   mistral:7b-q4_0   ~4.1 GB  — best quality for RTX 2070
#   codellama:7b      ~4.1 GB  — code-focused
DEFAULT_MODEL=qwen3:2b

# How long Ollama keeps a model in memory after the last request.
# Set to -1 to keep it loaded forever.
OLLAMA_KEEP_ALIVE=5m

# Max parallel requests (1 is fine for home use)
OLLAMA_NUM_PARALLEL=1

# GPU: max layers offloaded to VRAM. 99 = all layers (RTX 2070 can handle this
# for models up to ~7B Q4). Reduce if you get out-of-memory errors.
OLLAMA_GPU_LAYERS=99

# CPU: number of threads (default: 10 for Ryzen 5 1600)
OLLAMA_NUM_THREAD=10

# CPU: resource limits for Docker
CPU_LIMIT=10
MEM_LIMIT=12G

# Open WebUI
WEBUI_PORT=3000
WEBUI_SECRET_KEY=change-me-to-a-random-string
# Set to false after creating your first account
ENABLE_SIGNUP=true
