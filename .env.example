# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and edit as needed.
# .env is gitignored — never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Model ────────────────────────────────────────────────────────────────────
# Pulled automatically on first start. Any Ollama model tag works.
# Examples:
#   qwen3:2b          ~1.5 GB  — fast, great reasoning
#   minicpm5:1b       ~0.6 GB  — best under 2B, edge-optimised
#   llama3.2:3b       ~2.0 GB  — solid general purpose
#   mistral:7b-q4_0   ~4.1 GB  — best quality for RTX 2070
#   codellama:7b      ~4.1 GB  — code-focused
#   qwen3:8b          ~5.2 GB  — best reasoning (GPU only, fits RTX 2070 tight)
DEFAULT_MODEL=qwen3:2b

# ── Ollama runtime ───────────────────────────────────────────────────────────
# How long to keep a model in memory after the last request.
# Set to -1 to keep it loaded forever (faster subsequent requests).
OLLAMA_KEEP_ALIVE=5m

# Max parallel requests Ollama handles (1 is fine for home use).
OLLAMA_NUM_PARALLEL=1

# Allow browser → Ollama direct API calls from the lab UI.
# '*' works for local use; restrict to 'http://localhost:3001' for tighter security.
OLLAMA_ORIGINS=*

# ── GPU settings (docker-compose.gpu.yml) ────────────────────────────────────
# RTX 2070 has 8 GB VRAM. 99 = offload all layers. Reduce if OOM.
OLLAMA_GPU_LAYERS=99

# ── CPU settings (docker-compose.cpu.yml) ────────────────────────────────────
# Ryzen 5 1600 has 12 logical cores — use 10, leave 2 for the OS.
OLLAMA_NUM_THREAD=10
CPU_LIMIT=10
MEM_LIMIT=12G

# ── Lab UI (docker-compose.lab.yml) ──────────────────────────────────────────
# Port the custom experimentation UI is served on.
LAB_PORT=3001

# ── Open WebUI (docker-compose.webui.yml — optional) ─────────────────────────
WEBUI_PORT=3000
WEBUI_SECRET_KEY=change-me-to-a-random-string
# Set to false after you've created your first account.
ENABLE_SIGNUP=true
